#include "thingProperties.h"

const char* FIRMWARE_VERSION = "1.0.0";
unsigned long lastCounterMillis = 0;
const unsigned long counterInterval = 10000;

void setup() {
  Serial.begin(115200);
  delay(1500);
  initProperties();
  ArduinoCloud.begin(ArduinoIoTPreferredConnection);
  setDebugMessageLevel(2);
  ArduinoCloud.printDebugInfo();
  firmwareVersionCloud = FIRMWARE_VERSION;
  deviceStatus = "V1 Online";
  Serial.println("Firmware V1 - boot selesai");
}

void loop() {
  ArduinoCloud.update();
  updateCounterV1();
  readSensorDummy();
}

void readSensorDummy() {
  smokeLevel = random(200, 800);
}

void updateCounterV1() {
  if (millis() - lastCounterMillis >= counterInterval) {
    otaCounter++;
    lastCounterMillis = millis();
    deviceStatus = "V1 Online - tick " + String(otaCounter);
    Serial.print("V1 tick: ");
    Serial.println(otaCounter);
  }
}

void onLedStateChange() {}
void onDeviceStatusChange() {}
void onFirmwareVersionCloudChange() {}
void onOtaCounterChange() {}
void onSmokeLevelChange() {}
